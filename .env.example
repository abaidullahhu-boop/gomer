# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Frontend URL used for post-OAuth redirect and CORS origin
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gomer
DATABASE_USER=postgres
DATABASE_PASSWORD=password

DATABASE_URL=postgresql://postgres:password@localhost:5432/gomer

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Slack OAuth
# ─────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback
# Comma-separated OAuth scopes requested from Slack
SLACK_SCOPES=chat:write,users:read,users:read.email,team:read

# ─────────────────────────────────────────────
# Pipedream Connect (managed integrations)
# ─────────────────────────────────────────────
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
# development | production
PIPEDREAM_ENVIRONMENT=development

# ─────────────────────────────────────────────
# AI (Anthropic Claude)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Defaults to claude-opus-4-8 when unset
AI_MODEL=claude-opus-4-8
